# Cairnkeep repo-local environment. Copy to .ai/.env and edit.
#
# The memory server uses an OpenAI-compatible endpoint for memory extraction and
# embedding-ranked search. Leave these unset to run memory in substring-only mode.
#
# CAIRN_LLM_API_KEY=
# CAIRN_LLM_API_URL=https://api.openai.com/v1
# CAIRN_LLM_EXTRACTION_MODEL=gpt-4o-mini
# CAIRN_MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# CAIRN_MEMORY_EMBEDDING_TIMEOUT_MS=15000
#
# Git host for the collaboration commands (memory-sync, repo-review, security-audit).
# One of: github | gitlab | codeberg | forgejo | none.  See docs/git-providers.md.
# CAIRN_GIT_PROVIDER=github
#
# Storage belongs to the host running the memory-server process. Named/global
# scopes default to ~/.cairnkeep; project scope uses <server-cwd>/.agentfs/.
# CAIRN_AGENTFS_BASE_DIR=~/.cairnkeep
#
# The memory server runs locally over stdio by default. These HTTP settings are
# for the SERVER host of an explicit remote deployment, not a normal local
# client. Setting MCP_HTTP_PORT REQUIRES a bearer token, or startup fails.
# CAIRN_MEMORY_HTTP_TOKEN=change-me-to-a-long-random-secret
# MCP_HTTP_PORT=7801
# MCP_HTTP_HOST=127.0.0.1
# Optional: comma-separated browser origins allowed via CORS (default: none).
# CAIRN_MEMORY_HTTP_ALLOWED_ORIGINS=
# Optional: comma-separated allowed Host headers for DNS-rebinding protection
# (default: the bind host + localhost on the chosen port).
# CAIRN_MEMORY_HTTP_ALLOWED_HOSTS=
#
# Optional document-RAG sync. API credentials and endpoint may be local or remote.
# ANYTHINGLLM_BASE_URL=http://localhost:3001
# ANYTHINGLLM_API_KEY=
# CAIRN_ANYTHINGLLM_PROJECTS_FILE=~/.config/cairnkeep/anythingllm-projects.json
# CAIRN_ANYTHINGLLM_STATE_FILE=~/.local/state/cairnkeep/anythingllm-sync.json
